{
  "identifier": "default",
  "description": "Default capabilities — no shell. dialog for workspace picker and confirms. start-dragging for overlay titlebar (Magic Trackpad). updater opt-in only.",
  "windows": ["main"],
  "local": true,
  "remote": {
    "urls": [
      "http://localhost:*",
      "http://127.0.0.1:*",
      "http://[::1]:*"
    ]
  },
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "dialog:allow-open",
    "dialog:allow-confirm",
    "dialog:allow-message",
    "updater:default"
  ]
}
