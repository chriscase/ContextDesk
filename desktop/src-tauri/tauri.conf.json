{
  "productName": "ContextDesk",
  "version": "0.1.0",
  "identifier": "cc.chriscase.contextdesk",
  "build": {
    "beforeDevCommand": "node scripts/gen-tauri-conf.mjs && npm run dev",
    "devUrl": "http://localhost:1450",
    "beforeBuildCommand": "node scripts/gen-tauri-conf.mjs && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "ContextDesk",
        "width": 1100,
        "height": 760,
        "resizable": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:*; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:",
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJBQzE0N0M2Mzc0MkJERkQKUldUOXZVSTN4a2ZCS3NWeElSTEF0ZllUOExaRFZJMlY1cVZvRm0wYzlIWGpJVHlLOFdXdEp6Z3EK",
      "endpoints": [
        "https://github.com/chriscase/ContextDesk/releases/latest/download/latest.json"
      ]
    }
  }
}
