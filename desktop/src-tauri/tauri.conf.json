{
  "productName": "ContextDesk",
  "version": "0.1.0",
  "identifier": "cc.chriscase.contextdesk",
  "build": {
    "beforeDevCommand": "node scripts/gen-tauri-conf.mjs && npm run dev",
    "devUrl": "http://localhost:1450",
    "beforeBuildCommand": "node scripts/gen-tauri-conf.mjs && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "ContextDesk",
        "width": 1100,
        "height": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:*; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
